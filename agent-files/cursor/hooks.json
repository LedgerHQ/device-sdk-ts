{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node agent-files/cursor/scripts/hooks/format.cjs"
      }
    ],
    "stop": [
      {
        "command": "node agent-files/cursor/scripts/hooks/post-task-checks.cjs",
        "timeout": 180,
        "loop_limit": 3
      }
    ]
  }
}
