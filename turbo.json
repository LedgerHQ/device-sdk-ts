{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", ".next/**"],
      "inputs": ["src/**/*.ts", "index.ts"]
    },
    "lint": {
      "dependsOn": ["build"],
      "env": ["ESLINT_PLUGIN_DIFF_COMMIT"]
    },
    "lint:fix": {
      "cache": false
    },
    "prettier": {},
    "prettier:fix": {
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.ts"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "@ledgerhq/device-management-kit-sample#typecheck": {
      "dependsOn": ["build", "^build"]
    },
    "@ledgerhq/ledger-dmk-docs#typecheck": {
      "dependsOn": ["build", "^build"]
    }
  }
}
