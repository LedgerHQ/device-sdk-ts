{
  "extends": "@ledgerhq/tsconfig-dsdk/tsconfig.web",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./lib/types",
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals"]
    "paths": {
      "@/*": ["./src/*"]
    },
  },
  "include": ["src", "vitest.*.mjs"]
}
