{
  "name": "dmk-debugger",
  "displayName": "DMK Debugger",
  "description": "VS Code extension for debugging Ledger Device Management Kit interactions — live log viewer, APDU analysis, and AI-powered diagnostics",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "private": true,
  "publisher": "ledgerhq",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dmk-debugger",
          "title": "DMK Debugger",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "dmk-debugger": [
        {
          "type": "webview",
          "id": "dmkDebugger.sidebar",
          "name": "DMK Debugger"
        }
      ]
    },
    "configuration": {
      "title": "DMK Debugger",
      "properties": {
        "dmkDebugger.server.port": {
          "type": "number",
          "default": 8432,
          "description": "Port for the log ingestion HTTP server"
        },
        "dmkDebugger.store.maxEntries": {
          "type": "number",
          "default": 10000,
          "description": "Maximum number of log entries to keep in memory"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "pnpm compile --watch",
    "lint": "eslint",
    "lint:fix": "pnpm lint --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@ledgerhq/eslint-config-dsdk": "workspace:*",
    "@ledgerhq/prettier-config-dsdk": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/vscode": "^1.93.0",
    "esbuild": "catalog:",
    "typescript": "catalog:"
  }
}
